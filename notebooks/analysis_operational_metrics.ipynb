import pandas as pd
import matplotlib.pyplot as plt

candidatos = 844
docs_por_candidato = 3

total_documentos = candidatos * docs_por_candidato

tempo_por_doc_min = 5

tempo_total_horas = (total_documentos * tempo_por_doc_min) / 60

tempo_total_horas

tempo_automatizado = 63

economia = tempo_total_horas - tempo_automatizado

reducao_percentual = economia / tempo_total_horas * 100

economia, reducao_percentual

labels = ["Manual", "Automatizado"]
tempos = [211, 63]

plt.bar(labels, tempos)
plt.title("Comparação de tempo operacional")
plt.ylabel("Horas")
plt.show()
